# Database (Supabase Postgres connection string)
# Prefer the *transaction* pooler (port 6543) for the API — session pooler (5432) caps at ~15 clients.
# Supabase Dashboard → Project Settings → Database → Connection string → Transaction pooler
DATABASE_URL=postgresql://postgres:password@localhost:5432/thetextapp
# Optional: cap server-side pool size (default 3). Keep low with Supabase free tier.
# DB_POOL_SIZE=3

# Supabase (for Realtime — enable replication on `messages` table)
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Server-side uploads to Supabase Storage (message-attachments bucket)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Better Auth
BETTER_AUTH_SECRET=change-me-to-a-32-char-minimum-secret-key
BETTER_AUTH_URL=http://localhost:9001

# Passkeys — web + mobile (HTTPS required in production)
PASSKEY_RP_ID=localhost
PASSKEY_ORIGIN=http://localhost:8081
# Expo web often binds to 8082 when 8081 is busy — include both in PASSKEY_ORIGINS if needed
# PASSKEY_ORIGINS=http://localhost:8082
# Android APK: add SHA-256 cert fingerprint origin
# PASSKEY_ORIGINS=android:apk-key-hash:ABC...,https://your-app.vercel.app

# MoQ relay — use local docker in dev (relay.moq.dev often fails DNS)
MOQ_RELAY_URL=http://localhost:4443/anon
# docker compose -f infra/docker/moq-relay.yml up -d

# CORS / trusted origins (comma-separated) — required when web app and API are on different hosts
# CORS_ORIGINS=https://your-app.vercel.app,http://localhost:8081,http://localhost:8082
# TRUSTED_ORIGINS=https://your-app.vercel.app,http://localhost:8081,http://localhost:8082,thetextapp://

# Server (Bun + Hono)
PORT=9001
NODE_ENV=development
